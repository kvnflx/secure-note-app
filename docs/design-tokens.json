{
  "$schema": "https://design-tokens.org/schema",
  "name": "secure-note-app",
  "version": "1.0.0",
  "color": {
    "light": {
      "bg": "#ffffff",
      "bg-subtle": "#f8fafc",
      "bg-muted": "#f1f5f9",
      "fg": "#0f172a",
      "fg-muted": "#475569",
      "fg-subtle": "#94a3b8",
      "border": "#e2e8f0",
      "border-strong": "#cbd5e1",
      "primary": "#0F4C96",
      "primary-hover": "#0A3972",
      "primary-fg": "#ffffff",
      "primary-subtle": "#dbeafe",
      "accent": "#2563EB",
      "danger": "#b91c1c",
      "danger-subtle": "#fee2e2",
      "success": "#047857",
      "warning": "#b45309"
    },
    "dark": {
      "bg": "#0A0E1A",
      "bg-subtle": "#0F172A",
      "bg-muted": "#1E293B",
      "fg": "#F8FAFC",
      "fg-muted": "#CBD5E1",
      "fg-subtle": "#64748B",
      "border": "#1E293B",
      "border-strong": "#334155",
      "primary": "#3B82F6",
      "primary-hover": "#60A5FA",
      "primary-fg": "#0A0E1A",
      "primary-subtle": "#1E3A8A",
      "accent": "#60A5FA",
      "danger": "#EF4444",
      "danger-subtle": "#7F1D1D"
    }
  },
  "font": {
    "family": {
      "sans": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", \"Inter\", \"Helvetica Neue\", Arial, sans-serif",
      "mono": "ui-monospace, \"JetBrains Mono\", \"SF Mono\", Menlo, Consolas, \"Liberation Mono\", monospace"
    },
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "6": "24px",
    "8": "32px",
    "12": "48px",
    "16": "64px"
  },
  "radius": {
    "sm": "4px",
    "base": "6px",
    "md": "8px",
    "lg": "12px"
  },
  "motion": {
    "fast": "150ms ease-out",
    "base": "200ms ease-in-out",
    "slow": "300ms ease-in-out"
  }
}
